# ============================================================
# Baseroot Marketplace — Environment Variables
# ============================================================
# Bu dosyayı kopyalayıp ".env" olarak adlandırın ve gerçek
# değerleri girin.  .env dosyası GitHub'a YÜKLENMEZ.
#
#   cp .env.example .env
# ============================================================

# ---------- Firebase (Client — VITE_ prefix) ----------
# Console: Project Settings → General → Your apps → Config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=baserootio
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=

# ---------- Firebase (Server — Admin SDK) ----------
# Console: Project Settings → Service Accounts → Generate New Private Key
# Tek satır JSON olarak yapıştırın
FIREBASE_PROJECT_ID=baserootio
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"baserootio",...}

# Firebase Emulator (sadece local dev — opsiyonel)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# VITE_USE_FIREBASE_EMULATOR=true

# ---------- Avalanche / Blockchain ----------
VITE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_EVM_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_BASEROOT_MARKETPLACE_ADDRESS=0xF501b1615CD3B8E98c658C3F269A498c63A1D5Cb
BASEROOT_MARKETPLACE_ADDRESS=0xF501b1615CD3B8E98c658C3F269A498c63A1D5Cb
VITE_PLATFORM_WALLET=your-platform-wallet-address
PLATFORM_WALLET=your-platform-wallet-address
DEPLOYER_PRIVATE_KEY=your-deployer-private-key

# ---------- WalletConnect ----------
VITE_WALLETCONNECT_PROJECT_ID=3fcc6bf1e3e7100b0e5170d1ed0de1d6

# ---------- ChainGPT ----------
CHAINGPT_API_KEY=your-chaingpt-api-key
CHAINGPT_BASE_URL=https://api.chaingpt.org
CHAINGPT_MODEL=general_assistant
CHAINGPT_TIMEOUT_MS=30000

# ---------- Pricing ----------
UNIT_PRICE_PER_TOKEN=0.00005
FLAT_PRICE_USD=0.05
PRICE_PER_CREDIT=0.05

# ---------- Revenue Split (basis points, toplam = 10000) ----------
SPLIT_DAO_BPS=5000
SPLIT_AGENT_DEV_BPS=3000
SPLIT_PROTOCOL_BPS=2000

# ---------- Admin / Auth ----------
ADMIN_BOOTSTRAP_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-secret
BASEROOT_WEBHOOK_SECRET=change-me-to-a-random-secret
ALLOWED_DAO_IDS=

# ---------- OAuth / Forge ----------
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ---------- Server ----------
PORT=3000
POC_PORT=3001
NODE_ENV=development
DATABASE_URL=
