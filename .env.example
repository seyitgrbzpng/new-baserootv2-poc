# Firebase Configuration

# Client (Vite) Firebase Config
# Project Settings → General → Your apps → Firebase SDK snippet (Config)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=baserootio
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
# Optional
VITE_FIREBASE_MEASUREMENT_ID=

# Get your Firebase project credentials from: https://console.firebase.google.com
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=baserootio
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"baserootio","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-fbsvc@baserootio.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40baserootio.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Firebase Emulator (for local development)
# Uncomment these lines to use Firebase Emulator
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# VITE_USE_FIREBASE_EMULATOR=true

# Server Configuration
PORT=3000
NODE_ENV=development

# Solana Configuration
VITE_SOLANA_NETWORK=devnet
VITE_PLATFORM_WALLET=your-platform-wallet-address

# Note: For Vercel deployment, add these environment variables in:
# Vercel Dashboard → Your Project → Settings → Environment Variables
# 
# IMPORTANT: For production, store FIREBASE_SERVICE_ACCOUNT as a single-line JSON string
# Remove all newlines from the private_key field and escape quotes if necessary

# Admin bootstrap (first admin setup)
# Use this secret in header: x-admin-secret
ADMIN_BOOTSTRAP_SECRET=change-me-to-a-long-random-string

# ============================================================================
# ChainGPT PoC — LLM Integration & Economic Attribution
# ============================================================================

# ChainGPT API (required for agentRun.run)
CHAINGPT_API_KEY=your-chaingpt-api-key
CHAINGPT_BASE_URL=https://api.chaingpt.org
CHAINGPT_MODEL=general_assistant
CHAINGPT_TIMEOUT_MS=30000

# Pricing (defaults shown)
UNIT_PRICE_PER_TOKEN=0.00005
FLAT_PRICE_USD=0.05
PRICE_PER_CREDIT=0.05

# Attribution Split — basis points, must sum to 10000
SPLIT_AGENT_BPS=7000
SPLIT_PLATFORM_BPS=2000
SPLIT_INFRA_BPS=1000

# DAO Access Control (comma-separated allowed DAO IDs, empty = allow all)
ALLOWED_DAO_IDS=dao_test_001,dao_demo

# Webhook HMAC Secret (optional, for /v1/events endpoint)
BASEROOT_WEBHOOK_SECRET=change-me-to-a-random-secret
